# ── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://eventi:eventi_local_dev@localhost:5432/eventi_dtd"

# ── Jitsi ────────────────────────────────────────────
# Must match docker-compose Jitsi JWT config
JITSI_JWT_SECRET="s3cr3t_dev_only"
JITSI_JWT_APP_ID="eventi_dtd"
JITSI_JWT_ISSUER="eventi-dtd"
JITSI_JWT_AUDIENCE="jitsi"

# Public URL of the Jitsi Web instance (used in IFrame API)
NEXT_PUBLIC_JITSI_DOMAIN="localhost:8443"

# ── App ──────────────────────────────────────────────
# Base URL of the eventi-dtd portal
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret for signing moderator tokens and internal JWTs
APP_SECRET="change_me_in_production"

# Default locale
NEXT_PUBLIC_DEFAULT_LOCALE="it"

# ── Email (SMTP) ─────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="eventi@dominio.gov.it"
SMTP_FROM_NAME="Eventi DTD"

# ── GDPR ─────────────────────────────────────────────
# Encryption key for PII at rest (32 bytes, hex encoded)
PII_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Default privacy policy URL
DEFAULT_PRIVACY_POLICY_URL="https://eventi.dominio.gov.it/privacy"

# Default data retention (days after event ends)
DEFAULT_DATA_RETENTION_DAYS="30"

# ── Azure Blob Storage (recordings) ─────────────────
# Uncomment for production
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER="recordings"

# ── Cron ──────────────────────────────────────────────
# API key for cron endpoints (reminder emails, cleanup)
CRON_API_KEY="dev_cron_key_change_in_production"

# ── Admin ─────────────────────────────────────────
# Access key for the admin panel (event creation)
ADMIN_API_KEY="change_me_admin_key_in_production"

# ── Branding ─────────────────────────────────────────
# Custom watermark image URL (overrides static file)
# NEXT_PUBLIC_WATERMARK_URL=""

# ── Docker (local dev) ──────────────────────────────
# IP of the Docker host for JVB
DOCKER_HOST_ADDRESS="host.docker.internal"
