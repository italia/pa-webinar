{
  "name": "pa-webinar",
  "version": "0.5.1",
  "private": true,
  "description": "Piattaforma open-source per eventi pubblici digitali del DTD",
  "license": "EUPL-1.2",
  "workspaces": [
    "app",
    "lobby"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "build": "npm run build --workspace=app",
    "start": "npm run start --workspace=app",
    "lint": "npm run lint --workspace=app",
    "test": "npm run test --workspace=app",
    "test:e2e": "npm run test:e2e --workspace=app",
    "db:push": "npm run db:push --workspace=app",
    "db:migrate": "npm run db:migrate --workspace=app",
    "db:studio": "npm run db:studio --workspace=app",
    "format": "prettier --write .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lobby:dev": "npm run dev --workspace=lobby",
    "lobby:build": "npm run build --workspace=lobby",
    "lobby:typecheck": "npm run typecheck --workspace=lobby",
    "license:report": "node scripts/generate-license-report.mjs",
    "changelog:md": "node scripts/generate-changelog-md.mjs"
  },
  "overrides": {
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "@xmldom/xmldom": "^0.9.10",
    "fast-xml-builder": "^1.2.0",
    "postcss": "^8.5.10",
    "undici": "^7.28.0",
    "next": {
      "sharp": "^0.35.0",
      "postcss": "^8.5.10"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
