{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "id": null,
  "uid": "eventi-dtd-overview",
  "title": "eventi-dtd Overview",
  "description": "Monitoring dashboard for the eventi-dtd platform",
  "tags": ["eventi-dtd", "jitsi", "nextjs"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up{app=\"eventi-dtd\"}, namespace)",
        "current": { "text": "videocall", "value": "videocall" },
        "refresh": 2,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up{app=\"eventi-dtd\", namespace=\"$namespace\"}, instance)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Active Events",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "eventi_active_events{namespace=\"$namespace\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "title": "Total Participants",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "eventi_jvb_participants{namespace=\"$namespace\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "title": "Registrations (total)",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "eventi_registrations_total{namespace=\"$namespace\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Uptime (24h)",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "avg_over_time(up{namespace=\"$namespace\", app=\"eventi-dtd\"}[24h]) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 99.9 }] } } }
    },
    {
      "title": "Error Rate",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "rate(http_requests_total{namespace=\"$namespace\", app=\"eventi-dtd\", status_code=~\"5..\"}[5m]) / rate(http_requests_total{namespace=\"$namespace\", app=\"eventi-dtd\"}[5m]) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "title": "App Version",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "count(up{namespace=\"$namespace\", app=\"eventi-dtd\"}) by (instance)", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Application Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Request Rate (by status code)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", app=\"eventi-dtd\"}[5m])) by (status_code)", "legendFormat": "{{status_code}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Latency Percentiles",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", app=\"eventi-dtd\"}[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", app=\"eventi-dtd\"}[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", app=\"eventi-dtd\"}[5m]))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } } }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds{namespace=\"$namespace\", app=\"eventi-dtd\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Jitsi / JVB",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Participants Over Time",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "targets": [
        { "expr": "eventi_jvb_participants{namespace=\"$namespace\"}", "legendFormat": "Participants" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Conferences Over Time",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 15 },
      "targets": [
        { "expr": "eventi_jvb_conferences{namespace=\"$namespace\"}", "legendFormat": "Conferences" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "JVB Stress Level",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 15 },
      "targets": [
        { "expr": "eventi_jvb_stress_level{namespace=\"$namespace\"}", "legendFormat": "Stress" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] }, "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "ICE Success Rate",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 15 },
      "targets": [{ "expr": "jitsi_jvb_ice_succeeded_total{namespace=\"$namespace\"} / (jitsi_jvb_ice_succeeded_total{namespace=\"$namespace\"} + jitsi_jvb_ice_failed_total{namespace=\"$namespace\"}) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "title": "RTT / Jitter",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 15 },
      "targets": [
        { "expr": "jitsi_jvb_rtt_aggregate{namespace=\"$namespace\"}", "legendFormat": "RTT" },
        { "expr": "jitsi_jvb_jitter_aggregate{namespace=\"$namespace\"}", "legendFormat": "Jitter" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Bandwidth",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 19 },
      "targets": [
        { "expr": "jitsi_jvb_bit_rate_download{namespace=\"$namespace\"} / 1024", "legendFormat": "Download (Mbps)" },
        { "expr": "jitsi_jvb_bit_rate_upload{namespace=\"$namespace\"} / 1024", "legendFormat": "Upload (Mbps)" }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}[5m])", "legendFormat": "{{pod}} / {{container}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        { "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}", "legendFormat": "{{pod}} / {{container}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "JVB Scaling Events",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        { "expr": "increase(eventi_jvb_scaling_events_total{namespace=\"$namespace\", direction=\"up\"}[1h])", "legendFormat": "Scale Up" },
        { "expr": "increase(eventi_jvb_scaling_events_total{namespace=\"$namespace\", direction=\"down\"}[1h])", "legendFormat": "Scale Down" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Events Lifecycle",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Events by Status",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "targets": [
        { "expr": "eventi_events_total{namespace=\"$namespace\"}", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Registrations (total gauge)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "targets": [
        { "expr": "eventi_registrations_total{namespace=\"$namespace\"}", "legendFormat": "Total" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Peak Concurrent Participants",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "targets": [
        { "expr": "max_over_time(eventi_jvb_participants{namespace=\"$namespace\"}[1h])", "legendFormat": "Peak (1h window)" },
        { "expr": "eventi_jvb_participants{namespace=\"$namespace\"}", "legendFormat": "Current" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    }
  ]
}
