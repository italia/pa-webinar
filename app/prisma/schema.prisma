// ─── Questionnaires (fase A) ─────────────────────────
//
// Reusable question templates ("gruppi di domande") live at the site
// level and can be composed into per-event questionnaires. Every event
// can have at most one PRE_REGISTRATION questionnaire (rendered inside
// the registration form) and one POST_EVENT questionnaire (rendered on
// the post-event page after the call ends).
//
// An EventQuestionnaire aggregates 0..N QuestionTemplates (via
// QuestionnaireTemplateLink) plus 0..N ad-hoc QuestionItems that live
// only for this specific questionnaire. Rendering order: templates in
// link order, then ad-hoc items in sortOrder.
//
// Responses are one-per-(questionnaire, respondent). Respondent is
// either a Registration (authenticated via accessToken) or a guest
// (tracked via a nanoid stored in a short-lived cookie, same pattern
// used by PollVote and WordCloudSubmission).
//
// Fase A is strictly per-event: responses scadono con la retention
// dell'evento. La deduplica cross-evento dei campi profilo stabili è
// parte di fase B (ADR-011 — Person + rubrica).

enum QuestionItemType {
  SINGLE_CHOICE
  MULTI_CHOICE
  YES_NO
  LIKERT
  OPEN_TEXT
}

enum QuestionnairePlacement {
  PRE_REGISTRATION
  POST_EVENT
}

model QuestionTemplate {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String? @db.Text
  // System templates (seeded) cannot be deleted, only cloned.
  isSystem    Boolean @default(false) @map("is_system")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items         QuestionItem[]
  questionnaires QuestionnaireTemplateLink[]

  @@map("question_templates")
}

model QuestionItem {
  id String @id @default(uuid()) @db.Uuid

  // Polymorphic owner: exactly one of these is set.
  //   templateId set        → library item (reusable across events)
  //   questionnaireId set   → ad-hoc item for a specific event questionnaire
  // Enforced at the application layer (service helper) + a partial-unique
  // CHECK constraint added in the migration SQL.
  templateId      String? @map("template_id") @db.Uuid
  questionnaireId String? @map("questionnaire_id") @db.Uuid

  // Multilingual prompt: { it: "...", en: "..." }
  prompt Json @db.JsonB

  type QuestionItemType

  // For SINGLE_CHOICE / MULTI_CHOICE: array of multilingual option objects.
  //   [{ "it": "Sì", "en": "Yes" }, { "it": "No", "en": "No" }]
  // For YES_NO / OPEN_TEXT / LIKERT: null.
  options Json? @db.JsonB

  // For LIKERT: scale range + optional endpoint labels. Default 1..5.
  scaleMin      Int?  @map("scale_min")
  scaleMax      Int?  @map("scale_max")
  scaleMinLabel Json? @map("scale_min_label") @db.JsonB // i18n
  scaleMaxLabel Json? @map("scale_max_label") @db.JsonB // i18n

  required  Boolean @default(false)
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  template      QuestionTemplate?    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questionnaire EventQuestionnaire?  @relation("AdhocItems", fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers       QuestionnaireAnswer[]

  @@index([templateId, sortOrder])
  @@index([questionnaireId, sortOrder])
  @@map("question_items")
}

model EventQuestionnaire {
  id       String                 @id @default(uuid()) @db.Uuid
  eventId  String                 @map("event_id") @db.Uuid
  placement QuestionnairePlacement

  // Multilingual header text shown above the questionnaire.
  title       Json @default("{}") @db.JsonB
  description Json @default("{}") @db.JsonB

  // If true, submitting the registration requires answering all required
  // questions (for PRE_REGISTRATION) or the post-event page requires
  // submission before showing the thank-you state (for POST_EVENT).
  required Boolean @default(false)

  // Whether respondents can change their answers after first submit
  // (until the event retention deletes them). Default false — once
  // submitted, the response is frozen.
  allowEdit Boolean @default(false) @map("allow_edit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event       Event                       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  templates   QuestionnaireTemplateLink[]
  adhocItems  QuestionItem[]              @relation("AdhocItems")
  responses   QuestionnaireResponse[]

  // At most one pre-registration questionnaire and one post-event
  // questionnaire per event (the form UI enforces this too).
  @@unique([eventId, placement])
  @@map("event_questionnaires")
}

// M2M between an event questionnaire and the templates it includes.
// sortOrder governs the order in which the templates' items appear,
// before the ad-hoc items of the questionnaire.
model QuestionnaireTemplateLink {
  questionnaireId String @map("questionnaire_id") @db.Uuid
  templateId      String @map("template_id") @db.Uuid
  sortOrder       Int    @default(0) @map("sort_order")

  questionnaire EventQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  template      QuestionTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([questionnaireId, templateId])
  @@index([templateId])
  @@map("questionnaire_template_links")
}

model QuestionnaireResponse {
  id              String  @id @default(uuid()) @db.Uuid
  questionnaireId String  @map("questionnaire_id") @db.Uuid
  registrationId  String? @map("registration_id") @db.Uuid
  guestId         String? @map("guest_id")

  // Snapshot of respondent name/email at submit time. For guests this is
  // the only place the name is stored (no Registration row). For registered
  // respondents this duplicates Registration fields — useful for dashboards
  // that survive the cascade when a registration is GDPR-cleaned up before
  // the questionnaire response itself is purged.
  respondentName  String? @map("respondent_name")
  respondentEmailHash String? @map("respondent_email_hash")

  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  questionnaire EventQuestionnaire    @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  registration  Registration?         @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  answers       QuestionnaireAnswer[]

  @@unique([questionnaireId, registrationId])
  @@unique([questionnaireId, guestId])
  @@index([questionnaireId])
  @@map("questionnaire_responses")
}

model QuestionnaireAnswer {
  id         String @id @default(uuid()) @db.Uuid
  responseId String @map("response_id") @db.Uuid
  itemId     String @map("item_id") @db.Uuid

  // Exactly one of the three value fields is populated, driven by the
  // item's type:
  //   OPEN_TEXT           → valueText
  //   SINGLE_CHOICE       → valueChoices = [idx]
  //   MULTI_CHOICE        → valueChoices = [idx, idx, ...]
  //   YES_NO              → valueScale = 0 (no) | 1 (yes)
  //   LIKERT              → valueScale = N within [scaleMin..scaleMax]
  valueText    String? @map("value_text") @db.Text
  valueChoices Json?   @map("value_choices") @db.JsonB
  valueScale   Int?    @map("value_scale")

  createdAt DateTime @default(now()) @map("created_at")

  response QuestionnaireResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  item     QuestionItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([responseId, itemId])
  @@index([itemId])
  @@map("questionnaire_answers")
}

// ─── Person (rubrica, phase B) ───────────────────────────
//
// Cross-event identity: deduplicated by email hash. A Person row exists
// only when the user explicitly opts in to the address book during
// registration (GDPR Art. 6.1.a — separate consent, not bundled with
// the per-event Art. 6.1.b basis).
//
// Stable profile fields (organization, role) are copied from the latest
// registration on every re-registration; event-specific questionnaire
// answers are NOT — those live on QuestionnaireAnswer and expire with
// the event retention.
//
// See docs/adr/011-person-rubrica.md.
model Person {
  id        String @id @default(uuid()) @db.Uuid
  emailHash String @unique @map("email_hash")

  // Latest-known values, updated on each opt-in re-registration.
  displayName      String?           @map("display_name")
  organization     String?
  organizationRole String?           @map("organization_role")
  organizationType OrganizationType? @map("organization_type")

  // Explicit opt-in state. optedInAt is set when the participant checks
  // the rubrica consent box; optedOutAt is set when they exercise
  // Art. 21 opposition (via a dedicated endpoint or admin action).
  optedInToAddressBook Boolean   @default(false) @map("opted_in_to_address_book")
  optedInAt            DateTime? @map("opted_in_at")
  optedOutAt           DateTime? @map("opted_out_at")

  // Used by the inactivity retention cron (ADR-011). Refreshed on every
  // registration linked to this person.
  lastActiveAt    DateTime @default(now()) @map("last_active_at")
  retentionMonths Int      @default(24) @map("retention_months")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  registrations Registration[]
  invitations   EventInvitation[]

  @@index([optedInToAddressBook, lastActiveAt])
  @@map("persons")
}

// ── Email outbox ────────────────────────────────────────────
//
// Persistent queue for outgoing emails. Producers (registration API,
// reminder cron, notification helpers) insert a row; the processor
// cron (/api/cron/email-outbox) pulls PENDING rows with FOR UPDATE
// SKIP LOCKED, sends them via SMTP (pooled), and marks SENT or
// re-schedules with exponential backoff.
//
// Rationale: previously the registration API fired a non-blocking
// Promise that hit SMTP inside the app pod. SMTP handshake + slow
// upstream providers inflated tail latency and, worse, dropped mails
// silently on pod restart. The outbox makes delivery durable and
// decouples user-facing latency from SMTP.
enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

model EmailOutbox {
  id String @id @default(uuid()) @db.Uuid

  // Delivery target
  toAddress String @map("to_address")
  subject   String
  html      String
  text      String?
  // Array of { filename, contentBase64, contentType } — base64 so we
  // don't have to worry about binary encoding in JSONB.
  attachments Json? @db.JsonB

  // Scheduling
  status         EmailOutboxStatus @default(PENDING)
  attempts       Int               @default(0)
  nextAttemptAt  DateTime          @default(now()) @map("next_attempt_at")
  sentAt         DateTime?         @map("sent_at")
  lastError      String?           @map("last_error")

  // Free-form metadata for traceability — e.g. { kind: 'confirmation',
  // registrationId, eventId }. Not used by the processor; the producer
  // owns the shape.
  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Processor query: PENDING rows ready to be sent, oldest first.
  @@index([status, nextAttemptAt])
  @@map("email_outbox")
}
