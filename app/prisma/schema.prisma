generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Events ──────────────────────────────────────────────────

model Event {
  id          String @id @default(uuid()) @db.Uuid
  slug        String @unique
  title       Json   @default("{}") @db.JsonB
  description Json   @default("{}") @db.JsonB

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")
  timezone String   @default("Europe/Rome")

  maxParticipants Int @default(300) @map("max_participants")

  // Expected share of participants that will actually send media (mic
  // or webcam). Drives JVB sizing — a webinar with 100 attendees and
  // 20% senders is *very* different infra-load than 100 all-senders.
  // Percentage (0-100). Null inherits SiteSetting.defaultSenderRatioPct.
  expectedSenderRatioPct Int? @map("expected_sender_ratio_pct")

  // Soft exit / grace period in minutes past endsAt before the scaler
  // transitions LIVE → ENDED. Null inherits SiteSetting.eventGracePeriodMinutes.
  //   0    → hard close at endsAt (legacy behaviour)
  //   N>0  → show "event in overtime" banner, close at endsAt+N
  //   -1   → never auto-close on endsAt; let the inactivity cleanup cron decide
  gracePeriodMinutes Int? @map("grace_period_minutes")

  // Jitsi room configuration
  jitsiRoomName String @unique @map("jitsi_room_name") // UUID-based

  // Feature toggles
  qaEnabled        Boolean @default(true) @map("qa_enabled")
  chatEnabled      Boolean @default(false) @map("chat_enabled")
  // Agenda/note live (opt-in): checklist dei punti da trattare che i
  // moderatori spuntano durante l'evento. Off di default → quando spenta
  // non mostra nulla; attivabile in creazione o durante l'evento.
  agendaEnabled    Boolean @default(false) @map("agenda_enabled")
  // Lavagna condivisa (whiteboard Excalidraw nativa di Jitsi): opt-in per
  // evento, off di default. Il pulsante compare ai moderatori (desktop) solo
  // se ON E se l'infra whiteboard è abilitata lato Jitsi (config.whiteboard.
  // enabled, oggi solo su test) → resta nascosto in prod finché non replicata.
  whiteboardEnabled Boolean @default(false) @map("whiteboard_enabled")
  // Nuvola di parole live: opt-in, OFF di default. Rimossa come funzione
  // sempre-attiva (poco usata; in prospettiva sostituita da una sintesi AI).
  // Attivabile dal moderatore durante l'evento (barra funzioni).
  wordCloudEnabled Boolean @default(false) @map("word_cloud_enabled")
  recordingEnabled Boolean @default(false) @map("recording_enabled")

  // When recording is enabled, this skips the "start recording?" moderator
  // prompt and starts the recording automatically as soon as the moderator
  // joins and Jibri is ready. Useful for events that want to guarantee
  // late-joiners have a player to catch up with. Ignored when
  // recordingEnabled is false.
  autoStartRecording Boolean @default(false) @map("auto_start_recording")

  // AV moderation settings
  participantsCanUnmute      Boolean @default(false) @map("participants_can_unmute")
  participantsCanStartVideo  Boolean @default(false) @map("participants_can_start_video")
  participantsCanShareScreen Boolean @default(false) @map("participants_can_share_screen")

  // Registration profiling toggles
  requireOrganization     Boolean @default(false) @map("require_organization")
  requireOrganizationRole Boolean @default(false) @map("require_organization_role")
  requireOrganizationType Boolean @default(false) @map("require_organization_type")

  // Moderator access
  moderatorToken String  @unique @map("moderator_token") // UUID for magic link
  moderatorName  String? @map("moderator_name")
  moderatorEmail String? @map("moderator_email")

  // Optional join password. When set, guests visiting /live without a
  // valid accessToken or matching password are redirected to a password
  // prompt before a Jitsi JWT is issued. Stored as a bcrypt hash — never
  // surfaced via any API response — and bypassed for admin / moderator
  // sessions (they already authenticated via magic link or JWT).
  joinPasswordHash String? @map("join_password_hash")

  // GDPR
  dataRetentionDays Int     @default(30) @map("data_retention_days")
  privacyPolicyUrl  String? @map("privacy_policy_url")
  privacyPolicyText String? @map("privacy_policy_text") @db.Text

  // Optional link to a shared GDPR template. When set, the event inherits
  // the template's multilingual body; privacyPolicyText can still override
  // per-event when a custom privacy notice is needed (the template is
  // primarily a default for admins who don't want to paste the same text
  // on every new event).
  gdprTemplateId String?       @map("gdpr_template_id") @db.Uuid
  gdprTemplate   GdprTemplate? @relation(fields: [gdprTemplateId], references: [id], onDelete: SetNull)

  // Additional info
  speakersInfo        Json    @default("{}") @map("speakers_info") @db.JsonB
  organizerName       String? @map("organizer_name")
  imageUrl            String? @map("image_url")
  waitingRoomAudioUrl String? @map("waiting_room_audio_url")

  // Event type
  eventType EventType @default(SCHEDULED) @map("event_type")

  // Status
  status EventStatus @default(DRAFT)

  // Scale-to-zero tracking: quando il JVB era effettivamente in uso l'ultima
  // volta (≥1 endpoint sul bridge per la room dell'evento). Popolato dallo
  // scaler ogni ciclo. Usato per IDLE → scale-down dopo INACTIVE_GRACE_MIN.
  lastActiveAt DateTime? @map("last_active_at")

  // Inizio transizione PROVISIONING (primo utente che apre la pagina di un
  // evento IDLE, o pre-scaling automatico prima di startsAt). Usato per
  // mostrare "sala in allestimento" e per il timeout di provisioning.
  provisioningStartedAt DateTime? @map("provisioning_started_at")

  // Temporary recording (catch-up, always active when LIVE if Jibri available)
  tempRecordingUrl       String?   @map("temp_recording_url")
  tempRecordingStartedAt DateTime? @map("temp_recording_started_at")

  // Published recording (moderator decision)
  recordingUrl             String?   @map("recording_url")
  recordingPublished       Boolean   @default(false) @map("recording_published")
  recordingPublishedAt     DateTime? @map("recording_published_at")
  recordingFileSize        BigInt?   @map("recording_file_size")
  recordingDuration        Int?      @map("recording_duration")
  recordingDeleteAfterDays Int?      @map("recording_delete_after_days")

  // Optional YouTube URL for legacy / mirrored recordings. When set, the
  // public video library prefers the embed over the self-hosted blob —
  // useful for events that were originally streamed or published on
  // YouTube before we owned the platform.
  youtubeUrl String? @map("youtube_url")

  // Whether the event is listed on the public /video-library hub.
  // Independent from `post_event_public` (which controls the detail
  // page's post-event view): an admin can keep a call's detail page
  // accessible to registered participants without exposing it to every
  // library visitor. Default false; INSTANT calls stay off by default
  // because they're usually internal / throw-away sessions.
  libraryListed Boolean @default(false) @map("library_listed")

  // 16:9 cover banner for the library card — higher-quality / more
  // curated than `image_url` (which may be a generic event graphic).
  // Optional: falls back to `image_url`, then to a generated gradient.
  coverImageUrl String? @map("cover_image_url")

  // Post-event configuration
  postEventPublic        Boolean   @default(true) @map("post_event_public")
  postEventPublicUntil   DateTime? @map("post_event_public_until")
  postEventShowQA        Boolean   @default(true) @map("post_event_show_qa")
  postEventShowMaterials Boolean   @default(true) @map("post_event_show_materials")
  postEventShowPolls     Boolean   @default(true) @map("post_event_show_polls")
  postEventShowFeedback  Boolean   @default(true) @map("post_event_show_feedback")
  postEventShowRecap     Boolean   @default(true) @map("post_event_show_recap")
  postEventShowWordCloud Boolean   @default(true) @map("post_event_show_word_cloud")
  feedbackEnabled        Boolean   @default(true) @map("feedback_enabled")

  // Post-event recap: an anonymized, aggregate snapshot (headcount, top
  // answered questions, published poll results, top word-cloud words, feedback
  // average) generated lazily on first view of the concluded page and PERSISTED
  // here so it survives the retention cleanup that deletes the raw rows.
  postEventRecap   Json?     @map("post_event_recap")
  postEventRecapAt DateTime? @map("post_event_recap_at")

  // Post-event follow-up email (opt-in per event). When enabled, the reminders
  // cron sends a thank-you + recap/feedback email to registrants and a recap
  // to the moderator once the event has ENDED. `postEventEmailSentAt` guards
  // against re-sending on subsequent cron runs.
  postEventEmailEnabled Boolean   @default(false) @map("post_event_email_enabled")
  postEventEmailSentAt  DateTime? @map("post_event_email_sent_at")

  // GDPR recording consent
  recordingConsentText String? @map("recording_consent_text") @db.Text

  // Analytics
  peakParticipants Int @default(0) @map("peak_participants")

  // Optional RRULE (RFC 5545) describing a recurring series. When set,
  // `recurrenceSeriesId` points to the "parent" event (the first occurrence)
  // and the scheduler will materialize children. When null, the event is a
  // one-off. The UI (wizard step 1) lets the admin choose a preset
  // (daily / weekly / weekdays / monthly / custom) which is compiled down
  // to this string — see app/src/lib/utils/recurrence.ts.
  recurrenceRule     String? @map("recurrence_rule") @db.VarChar(500)
  recurrenceSeriesId String? @map("recurrence_series_id") @db.Uuid
  recurrenceSeries   Event?  @relation("EventRecurrenceSeries", fields: [recurrenceSeriesId], references: [id], onDelete: SetNull)
  seriesChildren     Event[] @relation("EventRecurrenceSeries")

  // Per-feature role allowlist. Shape:
  //   { "chat": ["MODERATOR","SPEAKER","GUEST"], "qa": [...], "mic": [...],
  //     "video": [...], "share": [...], "recording_control": [...] }
  // When null, the UI falls back to the legacy boolean toggles (qaEnabled,
  // chatEnabled, participantsCanUnmute, ...). The wizard step 2 writes both
  // so old code paths keep working.
  permissionMatrix Json? @map("permission_matrix") @db.JsonB

  // Capacity estimate snapshot captured at create/update time (moderator
  // bandwidth, participant bandwidth, JVB count, storage, ...). Persisted
  // so we can later diff against real Prometheus metrics and tune the
  // estimate formula over time, and so Helm/autoscaler flows can pre-warm
  // the right number of JVB replicas for upcoming events.
  capacityEstimateJson Json? @map("capacity_estimate_json") @db.JsonB

  // Per-event override for the editorial "title with kicker" convention.
  // Null = inherit SiteSetting.parseTitleKicker. When set, overrides the
  // site-wide default for this event only — lets the admin force the
  // two-line kicker rendering on events whose title contains a `|` even
  // when the site default is off (or vice versa).
  parseTitleKicker Boolean? @map("parse_title_kicker")

  // Per-event override for the waiting-room engine. Null = inherit
  // SiteSetting.waitingRoomEngine. Lets an admin force the videogame lobby
  // (GAME), the SVG garden (GARDEN) or the static classic card (CLASSIC) on a
  // single event, regardless of the site-wide default.
  waitingRoomEngine WaitingRoomEngine? @map("waiting_room_engine")

  // Per-event override for the video/audio quality preset. Null = inherit
  // SiteSetting.videoQuality. Lets an admin force e.g. MAX on a small
  // high-stakes call, or SAVE_DATA on a low-bandwidth audience event.
  videoQuality VideoQuality? @map("video_quality")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  registrations   Registration[]
  questions       Question[]
  polls           Poll[]
  agendaItems     EventAgendaItem[]
  materials       EventMaterial[]
  reminders       EventReminder[]
  gdprAuditLogs   GdprAuditLog[]
  feedback        EventFeedback[]
  wordCloudRounds WordCloudRound[]
  callSessions    CallSession[]
  additionalMods  EventModerator[]
  organizers      EventOrganizer[]
  invitations     EventInvitation[]
  tagLinks        EventTagLink[]
  chatMessages    ChatMessage[]
  liveReactions   Reaction[]
  questionnaires  EventQuestionnaire[]
  recordings      Recording[]

  // ── Postprod AI feature flags (per-event) ─────────────────────
  // When true, the postprod pipeline produces a transcript / summary /
  // translations for the recording of this event. Off by default — the
  // admin opts in explicitly in the wizard step 5. The participant
  // disclosure text on the waiting room is driven from SiteSetting
  // (so the same notice can be edited PA-wide). Voice cloning is NOT
  // exposed here; that flow is V4 and gated by a separate workflow.
  aiTranscriptEnabled  Boolean @default(false) @map("ai_transcript_enabled")
  aiSummaryEnabled     Boolean @default(false) @map("ai_summary_enabled")
  aiTranslationEnabled Boolean @default(false) @map("ai_translation_enabled")
  // Dubbing TTS neutro nelle lingue target. Off di default — la voce
  // sintetica richiede disclosure prominente (AI Act Art. 50) anche se
  // non è voice clone. Generata SOLO se aiTranslationEnabled è true
  // (serve il transcript tradotto come input).
  aiDubbingEnabled     Boolean @default(false) @map("ai_dubbing_enabled")
  // ADR-013 Fase 3/5 — registrazione audio PER-PARTECIPANTE (multi-traccia)
  // per attribuzione speaker certa. OPT-IN esplicito dell'admin: l'audio
  // isolato del singolo parlante è PII ad alta sensibilità (vicino al
  // biometrico vocale), quindi NON va attivato automaticamente con la sola
  // trascrizione. Il recorder-controller crea un recorder SOLO per gli eventi
  // con questo flag + recordingEnabled + aiTranscriptEnabled. Le tracce sono
  // intermedie e cancellate dopo la trascrizione (multitrack-purge).
  multitrackRecordingEnabled Boolean @default(false) @map("multitrack_recording_enabled")
  // ADR-013 — opt-in a CONSERVARE le tracce per-partecipante oltre la
  // trascrizione (per archivio scaricabile + riascolto per-relatore in
  // video-library). Off di default = minimizzazione (purge subito dopo la
  // trascrizione). On = le tracce sopravvivono fino a retentionUntil del
  // recording, con disclosure/consenso dedicati (PII sensibile).
  retainParticipantTracks Boolean @default(false) @map("retain_participant_tracks")
  // Comma-separated ISO-639-1 list of target languages for transcript /
  // summary translation (e.g. "en,fr"). When null, falls back to
  // SiteSetting.aiDefaultTargetLocales.
  aiTargetLocales      String? @map("ai_target_locales") @db.VarChar(200)
  // Numero di parlanti attesi nell'evento. Quando valorizzato (1-30),
  // la pipeline forza `k = expectedSpeakers` nel clustering della
  // diarization invece di lasciare che il modello decida via silhouette
  // score. Tipicamente il moderatore lo conosce — il caso "dubbio"
  // (lascia null) è il default sicuro per i webinar pubblici.
  expectedSpeakers     Int?    @map("expected_speakers")

  // FK lookup index: "what events use this GDPR template" / cascade
  // SetNull on template delete.
  @@index([gdprTemplateId], map: "events_gdpr_template_id_idx")
  // FK lookup index: "find all events in this recurring series".
  @@index([recurrenceSeriesId], map: "events_recurrence_series_id_idx")
  // Hot path for the JVB scaler / monitoring queries that scan for
  // LIVE events with stale `last_active_at` (idle reaping).
  @@index([status, lastActiveAt], map: "events_status_last_active_idx")
  @@map("events")
}

// ─── Additional moderators / speakers ────────────────────────
//
// Beyond the primary `Event.moderatorToken` (which acts as the
// "owner" magic link), events can have any number of named grants
// with their own magic-link token. `role` splits them into:
//
//   - MODERATOR: full moderation powers (kick, mute-everyone,
//     recording, security, Q&A admin). Same capabilities as the
//     primary moderator token.
//   - SPEAKER ("relatore"): full AV rights (mic/camera/screen-share)
//     but no moderation powers. Intended for invited panelists who
//     shouldn't be able to end the event or kick people.
//
// Note: the table name stays `event_moderators` to avoid a disruptive
// rename; think of it as "named access grants for an event".
enum EventModeratorRole {
  MODERATOR
  SPEAKER
}

model EventModerator {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  name  String
  email String?

  role EventModeratorRole @default(MODERATOR)

  // Per-grant magic link token. Still UUID so `randomUUID()` from
  // crypto can generate it safely.
  token String @unique

  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_moderators")
}

// ─── Event organizers ────────────────────────────────────────
//
// Institutions / departments that co-organize the event. Purely
// display metadata — no access rights, no magic link, no email
// communication. Shown publicly on the event page (names + logo +
// optional link). Multiple organizers per event for sponsor lists
// or cross-department collaborations.
//
// Separate from `EventModerator` (which grants room access with a
// role) and from the legacy `Event.organizerName` single-string
// column (which we keep as a fallback for older events).
model EventOrganizer {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  name       String  @db.VarChar(200)
  logoUrl    String? @map("logo_url")
  websiteUrl String? @map("website_url")

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
  @@map("event_organizers")
}

// ─── Event invitations ───────────────────────────────────────
//
// Pre-registration list surfaced in the create-event wizard (step 3).
// Distinct from `Registration` (self-service signup) and from
// `EventModerator` (which grants access via magic link):
//   - GUEST    → will receive an email with a pre-filled registration
//                link; no special access granted, same flow as a public
//                registrant. Useful for curated lists like "internal team".
//   - SPEAKER  → shorthand for "create an EventModerator SPEAKER row on
//                invite-send"; kept here primarily as an editorial record.
//                Institutional co-organizers go to `EventOrganizer`, not
//                here.
// Optional `personId` links back to the Person rubrica so repeat invitees
// can be picked from the address book rather than retyped.
enum EventInvitationRole {
  GUEST
  SPEAKER
}

model EventInvitation {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId  String  @map("event_id") @db.Uuid
  personId String? @map("person_id") @db.Uuid

  role      EventInvitationRole @default(GUEST)
  name      String?             @db.VarChar(200)
  // `email` is encrypted (AES-256-GCM, base64) on new rows; legacy
  // rows may still hold plaintext until they are rewritten. The
  // (200 → 500) bump leaves room for the ciphertext.
  email     String              @db.VarChar(500)
  // Deterministic HMAC-SHA256 hex of the normalized email — populated
  // alongside the ciphertext so we keep the per-event uniqueness
  // guarantee (the random IV in `email` makes that column useless for
  // it). NULL for legacy plaintext rows; uniqueness on this column
  // applies only to non-NULL values, which is what Postgres does by
  // default.
  emailHash String?             @map("email_hash") @db.VarChar(64)

  // Magic-link token for the pre-filled registration page. Generated
  // server-side before the invitation email goes out; null until then
  // (e.g. for invitations staged in the wizard but not yet sent).
  token String? @unique

  sentAt     DateTime? @map("sent_at")
  acceptedAt DateTime? @map("accepted_at")
  declinedAt DateTime? @map("declined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([eventId, email], map: "event_invitations_event_email_ux")
  @@unique([eventId, emailHash])
  @@index([eventId])
  @@index([personId])
  @@map("event_invitations")
}

// ─── Tag taxonomy ────────────────────────────────────────────
//
// Reusable tags for classifying events (e.g. "Webinar", "Workshop",
// "Transizione Digitale"). Shown as small colored badges on the event
// card and used as a facet on the public /eventi list.
model Tag {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String  @unique @db.VarChar(100)
  name      Json    @default("{}") @db.JsonB
  color     String? @db.VarChar(10)
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events EventTagLink[]

  @@map("tags")
}

model EventTagLink {
  eventId String @map("event_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@index([tagId])
  @@map("event_tag_links")
}

// ─── Email templates ────────────────────────────────────────
//
// Admin-editable overrides for the system email templates. One row
// per (key, locale). Null fields fall back to the built-in defaults
// in src/lib/email/templates.ts — so a partial override works.
//
// Supported placeholders (whitelisted in the resolver):
//   {{eventTitle}}, {{eventDate}}, {{eventTime}}, {{eventDuration}},
//   {{joinUrl}}, {{eventPageUrl}}, {{siteName}}, {{offsetMinutes}}
//
// Keys mirror template modules: 'confirmation', 'reminder'.
// Adding a new key requires wiring the resolver; templates can't
// be invented solely from the UI.
model EmailTemplate {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key    String
  locale String

  subject    String?
  heading    String?
  bodyIntro  String? @db.Text
  ctaLabel   String?
  infoNote   String? @db.Text
  footerNote String? @db.Text

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@unique([key, locale])
  @@map("email_templates")
}

// ─── Chat messages ──────────────────────────────────────────
//
// In-app real-time chat for live events. Unlike the previous iteration
// (which used Jitsi XMPP as transport and was ephemeral), these rows
// persist so we can:
//   - rehydrate late joiners with /chat/history?since=…
//   - surface the transcript in the post-event page alongside Q&A
//   - feed the chat corpus into AI summary workflows (roadmap)
//   - export for GDPR / compliance requests
//
// Real-time fan-out is handled via Redis pub/sub (POST inserts a row
// and PUBLISHes on `chat:<eventId>`; SSE subscribers on any pod
// re-emit to their connected clients).
model ChatMessage {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  // Who sent it. We intentionally denormalize the sender's display
  // name — participant display names are mutable in Jitsi pre-join,
  // and for post-event history we want the name as it appeared in
  // the room, not the current one.
  //
  // PII: encrypted at rest via encryptPII (AES-256-GCM, see
  // src/lib/crypto/pii.ts). Reads must go through tryDecryptPII to
  // tolerate any pre-encryption legacy rows. Column type stays
  // String so no migration is required; ciphertext is base64.
  senderName  String  @map("sender_name")
  // Matches the participant's JWT uniqueId (mod-xxx / reg-xxx /
  // guest-xxx), so we can cluster messages by author for AI summary
  // even after display-name changes.
  senderId    String  @map("sender_id")
  // true when the caller authenticated via the moderator magic link.
  // Used by the UI to style moderator messages differently and by
  // moderation actions to prevent partecipanti from deleting others.
  isModerator Boolean @default(false) @map("is_moderator")

  // PII: message body is encrypted at rest with encryptPII
  // (AES-256-GCM). Reads decrypt via tryDecryptPII so legacy
  // plaintext rows still render. SSE fan-out publishes plaintext on
  // Redis — encryption is at-rest only.
  text String @db.Text

  // Soft-delete flag: moderator/admin can hide a message without
  // losing the audit trail. Hidden messages are excluded from
  // /history but kept in the archive for compliance.
  hiddenAt DateTime? @map("hidden_at")
  hiddenBy String?   @map("hidden_by")

  // Reply/quote: optional self-reference to the message being replied to.
  // SetNull on delete so hiding/removing a parent doesn't cascade-delete
  // replies (the UI degrades a dangling reply to "messaggio rimosso").
  replyToId String?       @map("reply_to_id") @db.Uuid
  replyTo   ChatMessage?  @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("ChatReply")

  // Optional single attachment. attachmentBlobPath is an opaque storage key
  // (not PII, plaintext). attachmentName is the original filename (PII →
  // encrypted at rest via encryptPII, read via tryDecryptPII). mime/size are
  // not PII. Only authenticated senders may attach (see chat upload route).
  attachmentBlobPath String? @map("attachment_blob_path")
  attachmentName     String? @map("attachment_name")
  attachmentMime     String? @map("attachment_mime")
  attachmentSize     BigInt? @map("attachment_size")

  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([replyToId])
  @@map("chat_messages")
}

// ─── GDPR Templates ─────────────────────────────────────────
//
// Reusable privacy notices shared across events. A template stores the
// privacy text in every enabled locale (JSON: {it: "...", en: "..."}).
// Events can either reference a template (inheriting the text) or keep
// their ad-hoc `privacyPolicyText`. The admin UI lets operators create,
// edit and select templates, so the same GDPR clauses don't need to be
// pasted into every new event form.
model GdprTemplate {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  description String? @db.Text
  // Localized body: { it: "...", en: "..." }; every enabled locale is
  // optional — missing locales fall back to the default site locale on
  // the event page.
  body        Json    @default("{}") @db.JsonB

  // True for the template the admin wants to pre-select on new events.
  // Only one template can be default at a time (enforced by a unique
  // partial index in the migration SQL).
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events Event[]

  @@map("gdpr_templates")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  PROVISIONING // JVB/nodo in allestimento: mostra "sala in allestimento"
  LIVE // JVB su + ≥1 partecipante connesso negli ultimi 2 min
  IDLE // LIVE senza partecipanti da ≥ INACTIVE_GRACE_MIN → JVB scalato a 0
  ENDED
  ARCHIVED
}

enum EventType {
  SCHEDULED
  INSTANT
  // Historical event imported from an external source (e.g. YouTube):
  // no Jitsi room, no registrations, no live flow — just metadata and
  // a `youtubeUrl` that the library / detail page can embed.
  LEGACY
}

enum OrganizationType {
  MINISTRY
  AGENCY
  REGION
  PROVINCE
  MUNICIPALITY
  ASL
  UNIVERSITY
  PUBLIC_ENTITY
  IN_HOUSE
  OTHER
}

// ─── Registrations ───────────────────────────────────────────

model Registration {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  displayName String @map("display_name") // encrypted at application level (encryptPII)
  email       String // encrypted at application level
  emailHash   String @map("email_hash") // SHA-256 for dedup & Jitsi JWT

  // Profiling (configurable per event)
  organization     String?           @map("organization")
  organizationRole String?           @map("organization_role")
  organizationType OrganizationType? @map("organization_type")

  // GDPR consent
  consentGiven                Boolean  @map("consent_given")
  consentTimestamp            DateTime @map("consent_timestamp")
  consentRecording            Boolean? @map("consent_recording") // null if event has no recording
  // ADR-013 Fase 5 — consenso esplicito SEPARATO alla registrazione audio
  // per-partecipante (traccia isolata = PII sensibile). Null se l'evento non
  // ha il multitrack abilitato; obbligatorio (true) per registrarsi se lo ha.
  consentMultitrack           Boolean? @map("consent_multitrack")
  consentFutureCommunications Boolean  @default(false) @map("consent_future_communications")

  // Access token (for personal join link)
  accessToken String @unique @map("access_token") // nanoid

  // Status
  joinedAt DateTime? @map("joined_at")
  leftAt   DateTime? @map("left_at")

  // Email tracking
  confirmationSentAt DateTime? @map("confirmation_sent_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Optional link to the cross-event Person (rubrica, phase B). Populated
  // only when the respondent explicitly opts in to the address book —
  // registrations without consent leave this null. See ADR-011.
  personId String? @map("person_id") @db.Uuid

  // ── AI postprod consent (Art. 6.1.a granular) ─────────────────
  // Three independent opt-ins surfaced in the waiting room when the
  // event has the corresponding `Event.ai*Enabled` flag on. Default
  // null = "not asked yet" (a registration created before the flag
  // existed); the live page treats null as "not consented" and
  // surfaces the prompt at join time. The pipeline filters
  // participant-level artifacts (chunked transcript lines etc.) by
  // checking these flags via the speaker → registration mapping.
  aiConsentTranscript  Boolean? @map("ai_consent_transcript")
  aiConsentSummary     Boolean? @map("ai_consent_summary")
  aiConsentTranslation Boolean? @map("ai_consent_translation")

  // Relations
  event                  Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person                 Person?                 @relation(fields: [personId], references: [id], onDelete: SetNull)
  questions              Question[]
  upvotes                QuestionUpvote[]
  pollVotes              PollVote[]
  agendaReactions        AgendaItemReaction[]
  remindersSent          ReminderSent[]
  feedback               EventFeedback[]
  questionnaireResponses QuestionnaireResponse[]

  @@unique([eventId, emailHash])
  @@index([personId])
  @@map("registrations")
}

// ─── Q&A ─────────────────────────────────────────────────────

model Question {
  id             String  @id @default(uuid()) @db.Uuid
  eventId        String  @map("event_id") @db.Uuid
  // Nullable so guests (no Registration row) can also submit questions
  // via the event live page. `authorName` stays authoritative: for
  // registrations it's copied from Registration.displayName, for guests
  // it's whatever the guest typed in the waiting room.
  registrationId String? @map("registration_id") @db.Uuid

  authorName String @map("author_name")
  text       String @db.VarChar(500)

  status      QuestionStatus @default(PENDING)
  upvoteCount Int            @default(0) @map("upvote_count") // denormalized

  createdAt     DateTime  @default(now()) @map("created_at")
  highlightedAt DateTime? @map("highlighted_at")
  answeredAt    DateTime? @map("answered_at")

  // Relations
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration Registration?    @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  upvotes      QuestionUpvote[]

  @@index([eventId, status, upvoteCount(sort: Desc)])
  @@map("questions")
}

enum QuestionStatus {
  PENDING
  HIGHLIGHTED
  ANSWERED
  DISMISSED
}

model QuestionUpvote {
  id             String @id @default(uuid()) @db.Uuid
  questionId     String @map("question_id") @db.Uuid
  registrationId String @map("registration_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  question     Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([questionId, registrationId])
  @@map("question_upvotes")
}

// ─── Polls ───────────────────────────────────────────────────

model Poll {
  id       String     @id @default(uuid()) @db.Uuid
  eventId  String     @map("event_id") @db.Uuid
  question String     @db.VarChar(300)
  options  Json // string[] of option texts
  status   PollStatus @default(OPEN)

  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  // Relations
  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([eventId, status])
  @@map("polls")
}

enum PollStatus {
  OPEN
  CLOSED
  PUBLISHED
}

model PollVote {
  id             String  @id @default(uuid()) @db.Uuid
  pollId         String  @map("poll_id") @db.Uuid
  registrationId String? @map("registration_id") @db.Uuid
  guestId        String? @map("guest_id")
  optionIndex    Int     @map("option_index")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll         Poll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([pollId, registrationId])
  @@unique([pollId, guestId])
  @@map("poll_votes")
}

// ─── Agenda / Note live (checklist punti da trattare) ───
// ADR: funzione opzionale (agendaEnabled). I moderatori definiscono i punti
// e li spuntano dal vivo; lo stato confluisce nella sintesi/descrizione AI.
model EventAgendaItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String  @map("event_id") @db.Uuid
  label     String  @db.VarChar(500)
  sortOrder Int     @default(0) @map("sort_order")
  completed Boolean @default(false)

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reactions AgendaItemReaction[]

  @@index([eventId])
  @@map("event_agenda_items")
}

// Assenso/dissenso dei partecipanti su un singolo punto d'agenda (audience
// pulse). L'opt-in segue agendaEnabled. Dedup allineato a PollVote: un voto
// per identità (partecipante registrato via registrationId, o guest anonimo
// via guestId). Cambiare valore fa upsert in place — nessun double-count.
enum AgendaReactionValue {
  AGREE
  DISAGREE
}

model AgendaItemReaction {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agendaItemId   String              @map("agenda_item_id") @db.Uuid
  registrationId String?             @map("registration_id") @db.Uuid
  guestId        String?             @map("guest_id")
  value          AgendaReactionValue
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  agendaItem   EventAgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  registration Registration?   @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([agendaItemId, registrationId])
  @@unique([agendaItemId, guestId])
  @@index([agendaItemId])
  @@map("agenda_item_reactions")
}

/// P1 analytics — LIVE emoji reactions (👏 ❤️ …) sent during a call from the
/// reaction bar. One row per reaction click (the POST is already self-originated
/// by the reactor, so there is no broadcast fan-out). No PII: only the emoji +
/// timestamp are stored, for post-event counts and the engagement timeline
/// (createdAt is absolute → placeable on the same axis as chat/Q&A). Distinct
/// from AgendaItemReaction (agenda 👍/👎 audience pulse). Deleted by the cleanup
/// cron for archived events.
model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("reactions")
}

// ─── Event Materials ────────────────────────────────────

model EventMaterial {
  id          String  @id @default(uuid()) @db.Uuid
  eventId     String  @map("event_id") @db.Uuid
  type        String  @default("LINK") // LINK or FILE
  title       String  @db.VarChar(300)
  url         String
  description String? @db.VarChar(500)
  addedBy     String  @map("added_by")

  // File-specific fields (type=FILE)
  fileName String? @map("file_name")
  fileSize BigInt? @map("file_size")
  mimeType String? @map("mime_type")
  blobPath String? @map("blob_path")

  // Visibility control
  visibility String @default("ALWAYS") @map("visibility") // ALWAYS, BEFORE, DURING, AFTER

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_materials")
}

// ─── Event Reminders ────────────────────────────────────

model EventReminder {
  id            String @id @default(uuid()) @db.Uuid
  eventId       String @map("event_id") @db.Uuid
  offsetMinutes Int    @map("offset_minutes") // e.g. 1440=1day, 60=1hour, 15=15min
  label         String @db.VarChar(100) // e.g. "1 giorno prima"

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sentRecords ReminderSent[]

  @@index([eventId])
  @@map("event_reminders")
}

model ReminderSent {
  id             String @id @default(uuid()) @db.Uuid
  reminderId     String @map("reminder_id") @db.Uuid
  registrationId String @map("registration_id") @db.Uuid

  sentAt DateTime @default(now()) @map("sent_at")

  // Relations
  reminder     EventReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  registration Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([reminderId, registrationId])
  @@map("reminder_sent")
}

// ─── GDPR Audit Log ────────────────────────────────────

model GdprAuditLog {
  id          String  @id @default(uuid()) @db.Uuid
  eventId     String  @map("event_id") @db.Uuid
  action      String // DATA_DELETED, CONSENT_RECORDED, DATA_EXPORTED
  recordCount Int     @map("record_count")
  details     String? @db.Text // JSON, no PII

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("gdpr_audit_logs")
}

// ─── Admin Action Audit Log ────────────────────────────
//
// Append-only log of mutating actions performed by admin sessions
// (event create/update/delete, recordings management, moderator
// rotation, settings changes, etc.). Read-only listings are NOT
// recorded — only writes — to keep volume manageable.
//
// Per Italian PA accountability expectations (and to satisfy any
// Garante audit) every privileged write must answer "chi ha fatto
// cosa e quando".

model AdminAuditLog {
  id        String  @id @default(uuid()) @db.Uuid
  // Hashed admin identifier. The current admin auth has no per-user
  // accounts (single shared ADMIN_API_KEY), so this is always a short
  // anonymous tag for now; if/when per-admin sessions land, swap in
  // the user id and the rest of the model still applies.
  actorHash String  @map("actor_hash")
  action    String // EVENT_CREATE, EVENT_UPDATE, EVENT_DELETE, RECORDING_DELETE, ...
  target    String? // free-form target identifier (event id, recording id, ...)
  ip        String?
  userAgent String? @map("user_agent") @db.Text
  details   String? @db.Text // JSON, no PII

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

// ─── Event Templates ─────────────────────────────────────

model EventTemplate {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String? @db.Text
  icon        String  @default("it-video")

  // Chat primaria, Q&A opt-in (live feedback #10 — "tenere SOLO chat"):
  // allineato a defaultMatrix() e ai template di sistema.
  qaEnabled                  Boolean @default(false) @map("qa_enabled")
  chatEnabled                Boolean @default(true) @map("chat_enabled")
  recordingEnabled           Boolean @default(false) @map("recording_enabled")
  autoStartRecording         Boolean @default(false) @map("auto_start_recording")
  // Pre-attiva la checklist/note live (Event.agendaEnabled) per gli eventi
  // creati da questo template. Modificabile nel wizard (step 2).
  agendaEnabled              Boolean @default(false) @map("agenda_enabled")
  // Pre-attiva la lavagna condivisa (Event.whiteboardEnabled) per gli eventi
  // creati da questo template. Modificabile nel wizard (step 2).
  whiteboardEnabled          Boolean @default(false) @map("whiteboard_enabled")
  // Motore sala d'attesa pre-popolato nel wizard (Event.waitingRoomEngine).
  // Nullable: null = usa il default del sito (SiteSetting.waitingRoomEngine).
  waitingRoomEngine          WaitingRoomEngine? @map("waiting_room_engine")
  participantsCanUnmute      Boolean @default(false) @map("participants_can_unmute")
  participantsCanStartVideo  Boolean @default(false) @map("participants_can_start_video")
  participantsCanShareScreen Boolean @default(false) @map("participants_can_share_screen")
  maxParticipants            Int     @default(300) @map("max_participants")

  // Default sensati per semplificare il wizard agli utenti meno esperti
  // (ADR: "default in base al template"). Pre-popolano i campi nel wizard
  // di creazione; restano tutti modificabili.
  // - defaultDurationMinutes: il wizard calcola endsAt = startsAt + durata,
  //   così l'utente imposta solo l'orario di inizio. Null = lascia +2h.
  defaultDurationMinutes Int?    @map("default_duration_minutes")
  // Pre-attivazione della pipeline AI per tipo di evento (es. un template
  // "Webinar registrato" attiva trascrizione + sintesi di default).
  aiTranscriptEnabled    Boolean @default(false) @map("ai_transcript_enabled")
  aiSummaryEnabled       Boolean @default(false) @map("ai_summary_enabled")
  aiTranslationEnabled   Boolean @default(false) @map("ai_translation_enabled")
  // Altri default che pre-popolano il wizard (modificabili):
  // - descriptionTemplate: testo descrizione multilingua pre-compilato.
  // - defaultRetentionDays: giorni di conservazione dati suggeriti.
  // - defaultExpectedSpeakers: n° relatori atteso (migliora la diarization).
  descriptionTemplate     Json? @map("description_template") @db.JsonB
  defaultRetentionDays    Int?  @map("default_retention_days")
  defaultExpectedSpeakers Int?  @map("default_expected_speakers")

  // Mirrors Event.permissionMatrix: when set, the role×feature matrix
  // is applied on new-event creation instead of the boolean toggles.
  permissionMatrix Json? @map("permission_matrix") @db.JsonB

  isSystem  Boolean  @default(false) @map("is_system")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("event_templates")
}

// ─── Site Settings ──────────────────────────────────────

model SiteSetting {
  id String @id @default("singleton")

  // Branding
  siteName              String  @default("PA Webinar") @map("site_name")
  siteDescription       String  @default("Piattaforma per eventi pubblici digitali") @map("site_description") @db.Text
  organizationName      String  @default("") @map("organization_name")
  organizationNameShort String  @default("") @map("organization_name_short")
  organizationUrl       String  @default("") @map("organization_url")
  parentOrganization    String  @default("") @map("parent_organization")
  parentOrganizationUrl String  @default("") @map("parent_organization_url")
  logoUrl               String? @map("logo_url")
  faviconUrl            String? @map("favicon_url")
  primaryColor          String  @default("#0066CC") @map("primary_color")

  // Timezone
  defaultTimezone String @default("Europe/Rome") @map("default_timezone")

  // SEO
  seoTitle       String  @default("PA Webinar") @map("seo_title")
  seoDescription String  @default("") @map("seo_description") @db.Text
  seoImage       String? @map("seo_image")

  // Home page
  homePageMode   HomePageMode @default(LANDING) @map("home_page_mode")
  customHomeHtml String?      @map("custom_home_html") @db.Text

  // Footer
  footerLinks Json @default("[]") @map("footer_links")

  // Pages content (Markdown or HTML) — multilingual JSON
  privacyPolicy Json @default("{}") @map("privacy_policy") @db.JsonB
  accessibility Json @default("{}") @map("accessibility") @db.JsonB

  // Feature toggles
  statusPageEnabled         Boolean @default(true) @map("status_page_enabled")
  guestAccessEnabled        Boolean @default(true) @map("guest_access_enabled")
  publicRegistrationEnabled Boolean @default(true) @map("public_registration_enabled")
  calendarPublic            Boolean @default(false) @map("calendar_public")

  // Editorial convention: when true, an event title containing `|` is rendered
  // with the part before the pipe as a small eyebrow/kicker label above the
  // main title. Off by default so existing titles never change appearance.
  parseTitleKicker Boolean @default(false) @map("parse_title_kicker")

  // Sala d'attesa: quale "engine" mostrare di default a tutti gli eventi.
  //   GARDEN  = giardino SVG interattivo (avatar, default storico)
  //   GAME    = lobby 2D Phaser (videogame, teatro + zone tematiche)
  //   CLASSIC = card statica (accessibile, niente animazioni)
  // Sovrascrivibile per-evento (Event.waitingRoomEngine) e via ?engine= URL.
  waitingRoomEngine WaitingRoomEngine @default(GARDEN) @map("waiting_room_engine")

  // Jitsi customization
  jitsiWatermarkUrl      String? @map("jitsi_watermark_url")
  jitsiWatermarkEnabled  Boolean @default(true) @map("jitsi_watermark_enabled")
  jitsiWatermarkOpacity  Float   @default(0.4) @map("jitsi_watermark_opacity")
  jitsiWatermarkPosition String  @default("bottom-left") @map("jitsi_watermark_position")

  // Default video/audio quality preset for all events. Overridable per event
  // (Event.videoQuality). HIGH = 720p with a capped bitrate (favours quality
  // without maxing bandwidth). See lib/jitsi/config.ts VIDEO_QUALITY_PRESETS.
  videoQuality VideoQuality @default(HIGH) @map("video_quality")

  // External links
  githubUrl    String? @map("github_url")
  supportEmail String? @map("support_email")

  // i18n / locale management
  defaultLocale        String @default("it") @map("default_locale")
  availableLocales     Json   @default("[\"it\",\"en\"]") @map("available_locales")
  localeNames          Json   @default("{\"it\":\"Italiano\",\"en\":\"English\"}") @map("locale_names")
  translationOverrides Json   @default("{}") @map("translation_overrides")

  // JVB scale-to-zero tuning
  // Minuti di conferenza vuota prima di marcare un evento LIVE come IDLE
  // e scalare il JVB a 0. Default: 45. Range consigliato: 15-120.
  jvbInactiveGraceMinutes  Int @default(45) @map("jvb_inactive_grace_minutes")
  // Minuti di lookahead per il pre-scaling di eventi PUBLISHED → PROVISIONING.
  // Il nodo viene avviato N minuti prima di startsAt. Default: 15.
  jvbPreScaleMinutes       Int @default(15) @map("jvb_pre_scale_minutes")
  // Finestra "vicino all'inizio" (minuti) entro cui la registrazione instrada
  // subito nella sala d'attesa; oltre (registrazione con ore di anticipo)
  // mostra la schermata di conferma con iCal invece della sala. 0 = mai
  // instradare in sala prima dell'inizio. Default 15 (feedback #1).
  waitingRoomLeadMinutes   Int @default(15) @map("waiting_room_lead_minutes")
  // Empty-conference authoritative close (feedback #12). Minuti che una sala
  // LIVE che HA avuto traffico può restare vuota prima che lo scaler la porti
  // DIRETTAMENTE a ENDED (terminale), PRIMA di endsAt e separatamente dalla
  // grace di scale-to-zero (jvbInactiveGraceMinutes/45m) e dalla grace di
  // overtime post-endsAt (eventGracePeriodMinutes/15m).
  //   -1  → disabilitato (default)
  //    0  → chiudi al primo tick a sala vuota (~cadenza cron)
  //   N>0 → chiudi dopo N minuti di sala COMPLETAMENTE vuota (moderatore incluso)
  // DISATTIVO di default: è un ENDED TERMINALE (non risvegliabile) e la review
  // ha evidenziato rischi reali (uno stato participants=0 stantìo/degradato
  // potrebbe chiudere una sala ancora piena; una pausa in cui esce anche il
  // moderatore chiuderebbe una sala a cui si voleva tornare). L'auto-chiusura
  // per inattività SICURA è già data dalla grace 45-min LIVE->IDLE (risvegliabile);
  // questo close terminale anticipato resta un opt-in configurabile da admin.
  jvbEmptyCloseMinutes     Int @default(-1) @map("jvb_empty_close_minutes")
  // Modalità reazioni (#7): 'NATIVE' = pulsante reazioni nativo di Jitsi nella
  // barra (effimere, nessuna analitica); 'CUSTOM' = barra reazioni custom
  // dell'app (persistite/aggregate). Default 'NATIVE'.
  reactionsMode            String @default("NATIVE") @map("reactions_mode")
  // Soglie di stress che attivano il reactive scale-up oltre al predictive.
  // Sopra la warn, aggiunge 1 replica; sopra la critical, 2. Entrambe
  // sono espresse come percentuale 0-100 per comodità dell'admin UI.
  // Default 50/70 = scale-up se lo stress supera rispettivamente 50% e 70%.
  jvbStressWarnPercent     Int @default(50) @map("jvb_stress_warn_percent")
  jvbStressCriticalPercent Int @default(70) @map("jvb_stress_critical_percent")

  // Timeout oltre il quale un evento LIVE/PROVISIONING senza JVB pronto
  // viene segnalato come "degraded" sulla status page (invece che come
  // "standby normale"). Default 15 min, copre cold-start del nodo F16
  // (~3-5 min) + boot JVB (~1 min) + margine di sicurezza.
  jvbProvisioningTimeoutMinutes Int @default(15) @map("jvb_provisioning_timeout_minutes")

  // Intervallo di polling della status page lato browser (secondi). Default
  // 30s — compromesso fra freschezza dei dati e carico sull'app.
  statusPollIntervalSeconds Int @default(30) @map("status_poll_interval_seconds")

  // Giorni di grace prima che un orfano (blob nello storage non linkato a
  // nessun Event/CallSession) venga cancellato automaticamente dal cron di
  // reconciliation. Default: 30. Durante la grace l'admin può decidere di
  // marcare l'orfano come "ignore" (mantenere) o "delete-now" (eliminare
  // subito). Impostare a 0 per disabilitare l'auto-cleanup.
  orphanRecordingGraceDays Int @default(30) @map("orphan_recording_grace_days")

  // ── JVB sizing calculator (admin-tunable, per-cluster) ─────────
  //
  // Il software è a riuso: diverse PA eseguono su hardware diverso
  // (F16s_v2, m5.xlarge, n2-standard-16, on-prem…). Lo scaler deve
  // calcolare il numero di repliche JVB da questi parametri invece che
  // da magic-number hard-coded.
  //
  // Default calibrati su Azure F16s_v2 (16 vCPU / 32 GiB) con pod
  // requests=14 core. Per nodo più piccolo/grande l'admin aggiorna qui
  // — non serve redeploy.
  jvbCpuCoresPerPod   Int   @default(16) @map("jvb_cpu_cores_per_pod")
  jvbReceiversPerCore Float @default(18.75) @map("jvb_receivers_per_core")
  jvbSendersPerCore   Float @default(3.125) @map("jvb_senders_per_core")
  jvbMaxReplicas      Int   @default(6) @map("jvb_max_replicas")
  jibriCpuCoresPerPod Int   @default(4) @map("jibri_cpu_cores_per_pod")

  // Frazione di partecipanti attesa come "sender" (mic o webcam attivi)
  // quando l'evento non ne specifica una. 30% è un buon default per
  // webinar interattivi; i template possono overridare (es. 100% per
  // call con tutti i partecipanti attivi, 10% per keynote).
  defaultSenderRatioPct Int @default(30) @map("default_sender_ratio_pct")

  // Soft exit: minuti di "overtime" concessi dopo endsAt prima di chiudere
  // la call. Mostrato come banner non invasivo ai partecipanti.
  //   0    → chiusura dura a endsAt (vecchio comportamento)
  //   N>0  → grace di N min, poi cleanup chiude la call
  //   -1   → non chiudere automaticamente, lascia al cleanup di inattività
  eventGracePeriodMinutes Int @default(15) @map("event_grace_period_minutes")

  // ── Postprod AI pipeline ──────────────────────────────────────
  // Master kill-switch: when false, the orchestrator skips creating
  // worker Jobs even if events have aiTranscriptEnabled=true (so an
  // operator can pause the pipeline cluster-wide without rolling out
  // a code change).
  aiPipelineEnabled       Boolean @default(false) @map("ai_pipeline_enabled")
  // Default target locales for translation when Event.aiTargetLocales
  // is null. Comma-separated ISO-639-1.
  aiDefaultTargetLocales  String  @default("en,fr") @map("ai_default_target_locales")
  // Provider routing — "vllm" or "ovh" (pluggable). The actual
  // endpoint URLs / secrets live in env vars (see lib/ai/providers).
  aiLlmProvider           String  @default("vllm") @map("ai_llm_provider")
  aiAsrProvider           String  @default("whisperx") @map("ai_asr_provider")
  // TTS engine per dubbing in lingue target. In-cluster only.
  //   "piper" → rhasspy/piper (MIT, ONNX, voci pre-trained per IT/EN/
  //             FR/DE/ES, ~8MB per voce, qualità adeguata per dubbing
  //             accessibility/operativo). Vendor: progetto OSS
  //             Mike Hansen (Rhasspy team).
  // Provider non-commerciali (Coqui XTTS-v2 CPML, Bark non-commercial)
  // sono esplicitamente esclusi dal default per uso PA.
  aiTtsEngine             String  @default("piper") @map("ai_tts_engine")
  // Max parallel worker Jobs the orchestrator will keep running on
  // the GPU node pool. Per-tick cap; total queue may be larger.
  aiMaxConcurrentJobs     Int     @default(2) @map("ai_max_concurrent_jobs")
  // How long an unclaimed PostprodJob can wait before the
  // orchestrator marks it FAILED (after attempts cap). Defaults align
  // with EmailOutbox backoff.
  aiJobMaxAttempts        Int     @default(5) @map("ai_job_max_attempts")
  // Retention for postprod artifacts (transcripts, summary, subtitles)
  // expressed in days from creation. 0 = follow the event retention
  // (default — artifacts vanish with the event). >0 = override (e.g.
  // 730 for "verbale come atto pubblico").
  aiArtifactRetentionDays Int     @default(0) @map("ai_artifact_retention_days")
  // Multilingual disclosure text shown on the waiting room when an
  // event opts into AI postprod. JSONB so editable per-locale.
  // Default empty → frontend falls back to a generic i18n string.
  aiConsentDisclosure     Json    @default("{}") @map("ai_consent_disclosure") @db.JsonB

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─── Orphan Recordings ──────────────────────────────
//
// Recordings live in object storage and are linked to Event/CallSession
// rows only when Jibri's finalize webhook succeeds. If the webhook fails
// (misconfigured room name, network error, expired event, etc.) the blob
// becomes an orphan: it exists in the bucket but nothing references it.
//
// A periodic reconciliation job scans the bucket, upserts unknown blobs
// here, and refreshes `lastSeenAt` on every run. A second job sweeps
// orphans with decision=pending past the configured grace period and
// deletes them from the bucket (and from this table).
//
// decision transitions:
//   pending    — discovered, awaiting admin review
//   ignore     — operator chose to keep; never auto-deleted
//   delete-now — operator chose to delete immediately on next sweep
model OrphanRecording {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blobName     String    @unique @map("blob_name")
  sizeBytes    BigInt?   @map("size_bytes")
  // The three timestamps below were created by the original migration
  // without a precision suffix, which Postgres treats as `timestamp` (=
  // `timestamp(6)`). Pin the precision in schema so `prisma migrate diff`
  // doesn't keep proposing a downgrade to `timestamp(3)`.
  lastModified DateTime? @map("last_modified") @db.Timestamp(6)
  discoveredAt DateTime  @default(now()) @map("discovered_at") @db.Timestamp(6)
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at") @db.Timestamp(6)
  decision     String    @default("pending") // pending | ignore | delete-now
  note         String?   @db.Text

  @@index([decision])
  @@index([discoveredAt])
  @@map("orphan_recordings")
}

enum HomePageMode {
  LANDING
  EVENTS_LIST
  CUSTOM
}

// Engine della sala d'attesa (pre-join). Vedi SiteSetting.waitingRoomEngine
// (default sito) e Event.waitingRoomEngine (override per-evento).
enum WaitingRoomEngine {
  GARDEN // giardino SVG interattivo (default storico)
  GAME // lobby 2D Phaser (videogame)
  CLASSIC // card statica (accessibile)
}

// Preset qualità video/audio. Vedi SiteSetting.videoQuality (default sito),
// Event.videoQuality (override per-evento) e lib/jitsi/config.ts per la
// mappatura sui parametri Jitsi (risoluzione, bitrate, Opus).
enum VideoQuality {
  SAVE_DATA // 360p, bitrate minimo (banda scarsa)
  BALANCED // 540p, compromesso
  HIGH // 720p, bitrate limitato (default — qualità senza saturare la banda)
  MAX // 1080p, alta fedeltà (call piccole importanti)
}

// ─── Event Feedback ─────────────────────────────────

model EventFeedback {
  id             String  @id @default(uuid()) @db.Uuid
  eventId        String  @map("event_id") @db.Uuid
  registrationId String? @map("registration_id") @db.Uuid
  guestId        String? @map("guest_id")
  rating         Int // 1-5
  comment        String? @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@unique([eventId, registrationId])
  @@unique([eventId, guestId])
  @@index([eventId])
  @@map("event_feedback")
}

// ─── Word Cloud ─────────────────────────────────────

model WordCloudRound {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  prompt    String    @db.VarChar(200)
  status    String    @default("OPEN") // OPEN, CLOSED
  duration  Int       @default(120)
  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  // Relations
  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submissions WordCloudSubmission[]

  @@index([eventId, status])
  @@map("word_cloud_rounds")
}

model WordCloudSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  roundId        String   @map("round_id") @db.Uuid
  registrationId String?  @map("registration_id") @db.Uuid
  guestId        String?  @map("guest_id")
  word           String   @db.VarChar(30)
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  round WordCloudRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@map("word_cloud_submissions")
}

// ─── Call Sessions ──────────────────────────────────

model CallSession {
  id            String @id @default(uuid()) @db.Uuid
  eventId       String @map("event_id") @db.Uuid
  jitsiRoomName String @map("jitsi_room_name")

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")
  duration  Int?

  peakParticipants Int  @default(0) @map("peak_participants")
  participants     Json @default("[]") @db.JsonB

  recordingUrl      String? @map("recording_url")
  recordingFileSize BigInt? @map("recording_file_size")
  recordingDuration Int?    @map("recording_duration")
  recordingFilename String? @map("recording_filename")

  telemetry Json @default("{}") @db.JsonB

  // ADR-013 Fase 0 — timeline del dominant speaker catturata in diretta
  // dall'IFrame API (`dominantSpeakerChanged`). Array append-only di
  // `{ atMs, participantId, displayName }` (displayName cifrato a valle
  // = PII). Post-evento serve ad attribuire i cluster pyannote ai
  // partecipanti reali (auto-naming) quando NON c'è registrazione
  // multi-traccia. Capped lato ingest per non gonfiare la riga.
  dominantSpeakerLog Json @default("[]") @map("dominant_speaker_log") @db.JsonB

  // P1 analytics — alzate di mano catturate in diretta dall'IFrame API
  // (`raiseHandUpdated`). Array append-only di `{ participantId, raised }`,
  // dove participantId è l'endpoint id OPACO della sessione del richiedente
  // (self-report: ogni client segnala solo la propria alzata → una riga per
  // alzata, niente PII e niente conteggio ~P×). Serve a contare "quante alzate
  // di mano" e da quante sessioni distinte. L'append è atomico (JsonB `||`) e
  // capped; scrubbato dal cleanup insieme a dominantSpeakerLog.
  handRaiseLog Json @default("[]") @map("hand_raise_log") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recording Recording?

  @@index([eventId])
  @@map("call_sessions")
}

// ─── Questionnaires (fase A) ─────────────────────────
//
// Reusable question templates ("gruppi di domande") live at the site
// level and can be composed into per-event questionnaires. Every event
// can have at most one PRE_REGISTRATION questionnaire (rendered inside
// the registration form) and one POST_EVENT questionnaire (rendered on
// the post-event page after the call ends).
//
// An EventQuestionnaire aggregates 0..N QuestionTemplates (via
// QuestionnaireTemplateLink) plus 0..N ad-hoc QuestionItems that live
// only for this specific questionnaire. Rendering order: templates in
// link order, then ad-hoc items in sortOrder.
//
// Responses are one-per-(questionnaire, respondent). Respondent is
// either a Registration (authenticated via accessToken) or a guest
// (tracked via a nanoid stored in a short-lived cookie, same pattern
// used by PollVote and WordCloudSubmission).
//
// Fase A is strictly per-event: responses scadono con la retention
// dell'evento. La deduplica cross-evento dei campi profilo stabili è
// parte di fase B (ADR-011 — Person + rubrica).

enum QuestionItemType {
  SINGLE_CHOICE
  MULTI_CHOICE
  YES_NO
  LIKERT
  OPEN_TEXT
}

enum QuestionnairePlacement {
  PRE_REGISTRATION
  POST_EVENT
}

model QuestionTemplate {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String? @db.Text
  // System templates (seeded) cannot be deleted, only cloned.
  isSystem    Boolean @default(false) @map("is_system")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items          QuestionItem[]
  questionnaires QuestionnaireTemplateLink[]

  @@map("question_templates")
}

model QuestionItem {
  id String @id @default(uuid()) @db.Uuid

  // Polymorphic owner: exactly one of these is set.
  //   templateId set        → library item (reusable across events)
  //   questionnaireId set   → ad-hoc item for a specific event questionnaire
  // Enforced at the application layer (service helper) + a partial-unique
  // CHECK constraint added in the migration SQL.
  templateId      String? @map("template_id") @db.Uuid
  questionnaireId String? @map("questionnaire_id") @db.Uuid

  // Multilingual prompt: { it: "...", en: "..." }
  prompt Json @db.JsonB

  type QuestionItemType

  // For SINGLE_CHOICE / MULTI_CHOICE: array of multilingual option objects.
  //   [{ "it": "Sì", "en": "Yes" }, { "it": "No", "en": "No" }]
  // For YES_NO / OPEN_TEXT / LIKERT: null.
  options Json? @db.JsonB

  // For LIKERT: scale range + optional endpoint labels. Default 1..5.
  scaleMin      Int?  @map("scale_min")
  scaleMax      Int?  @map("scale_max")
  scaleMinLabel Json? @map("scale_min_label") @db.JsonB // i18n
  scaleMaxLabel Json? @map("scale_max_label") @db.JsonB // i18n

  required  Boolean @default(false)
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  template      QuestionTemplate?     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questionnaire EventQuestionnaire?   @relation("AdhocItems", fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers       QuestionnaireAnswer[]

  @@index([templateId, sortOrder])
  @@index([questionnaireId, sortOrder])
  @@map("question_items")
}

model EventQuestionnaire {
  id        String                 @id @default(uuid()) @db.Uuid
  eventId   String                 @map("event_id") @db.Uuid
  placement QuestionnairePlacement

  // Multilingual header text shown above the questionnaire.
  title       Json @default("{}") @db.JsonB
  description Json @default("{}") @db.JsonB

  // If true, submitting the registration requires answering all required
  // questions (for PRE_REGISTRATION) or the post-event page requires
  // submission before showing the thank-you state (for POST_EVENT).
  required Boolean @default(false)

  // Whether respondents can change their answers after first submit
  // (until the event retention deletes them). Default false — once
  // submitted, the response is frozen.
  allowEdit Boolean @default(false) @map("allow_edit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event      Event                       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  templates  QuestionnaireTemplateLink[]
  adhocItems QuestionItem[]              @relation("AdhocItems")
  responses  QuestionnaireResponse[]

  // At most one pre-registration questionnaire and one post-event
  // questionnaire per event (the form UI enforces this too).
  @@unique([eventId, placement])
  @@map("event_questionnaires")
}

// M2M between an event questionnaire and the templates it includes.
// sortOrder governs the order in which the templates' items appear,
// before the ad-hoc items of the questionnaire.
model QuestionnaireTemplateLink {
  questionnaireId String @map("questionnaire_id") @db.Uuid
  templateId      String @map("template_id") @db.Uuid
  sortOrder       Int    @default(0) @map("sort_order")

  questionnaire EventQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  template      QuestionTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([questionnaireId, templateId])
  @@index([templateId])
  @@map("questionnaire_template_links")
}

model QuestionnaireResponse {
  id              String  @id @default(uuid()) @db.Uuid
  questionnaireId String  @map("questionnaire_id") @db.Uuid
  registrationId  String? @map("registration_id") @db.Uuid
  guestId         String? @map("guest_id")

  // Snapshot of respondent name/email at submit time. For guests this is
  // the only place the name is stored (no Registration row). For registered
  // respondents this duplicates Registration fields — useful for dashboards
  // that survive the cascade when a registration is GDPR-cleaned up before
  // the questionnaire response itself is purged.
  respondentName      String? @map("respondent_name")
  respondentEmailHash String? @map("respondent_email_hash")

  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  questionnaire EventQuestionnaire    @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  registration  Registration?         @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  answers       QuestionnaireAnswer[]

  @@unique([questionnaireId, registrationId])
  @@unique([questionnaireId, guestId])
  @@index([questionnaireId])
  @@map("questionnaire_responses")
}

model QuestionnaireAnswer {
  id         String @id @default(uuid()) @db.Uuid
  responseId String @map("response_id") @db.Uuid
  itemId     String @map("item_id") @db.Uuid

  // Exactly one of the three value fields is populated, driven by the
  // item's type:
  //   OPEN_TEXT           → valueText
  //   SINGLE_CHOICE       → valueChoices = [idx]
  //   MULTI_CHOICE        → valueChoices = [idx, idx, ...]
  //   YES_NO              → valueScale = 0 (no) | 1 (yes)
  //   LIKERT              → valueScale = N within [scaleMin..scaleMax]
  valueText    String? @map("value_text") @db.Text
  valueChoices Json?   @map("value_choices") @db.JsonB
  valueScale   Int?    @map("value_scale")

  createdAt DateTime @default(now()) @map("created_at")

  response QuestionnaireResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  item     QuestionItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([responseId, itemId])
  @@index([itemId])
  @@map("questionnaire_answers")
}

// ─── Person (rubrica, phase B) ───────────────────────────
//
// Cross-event identity: deduplicated by email hash. A Person row exists
// only when the user explicitly opts in to the address book during
// registration (GDPR Art. 6.1.a — separate consent, not bundled with
// the per-event Art. 6.1.b basis).
//
// Stable profile fields (organization, role) are copied from the latest
// registration on every re-registration; event-specific questionnaire
// answers are NOT — those live on QuestionnaireAnswer and expire with
// the event retention.
//
// See docs/adr/011-person-rubrica.md.
model Person {
  id        String @id @default(uuid()) @db.Uuid
  emailHash String @unique @map("email_hash")

  // Latest-known values, updated on each opt-in re-registration.
  // displayName is encrypted at rest via encryptPII (AES-256-GCM) — write
  // through encryptPIIOrNull, read through tryDecryptPII. Ciphertext makes
  // `contains` search and alphabetical orderBy meaningless, so the admin
  // rubrica route only searches on `organization` and orders by
  // `lastActiveAt`. See ADR-011 and app/src/lib/crypto/pii.ts.
  displayName      String?           @map("display_name")
  organization     String?
  organizationRole String?           @map("organization_role")
  organizationType OrganizationType? @map("organization_type")

  // Explicit opt-in state. optedInAt is set when the participant checks
  // the rubrica consent box; optedOutAt is set when they exercise
  // Art. 21 opposition (via a dedicated endpoint or admin action).
  optedInToAddressBook Boolean   @default(false) @map("opted_in_to_address_book")
  optedInAt            DateTime? @map("opted_in_at")
  optedOutAt           DateTime? @map("opted_out_at")

  // Used by the inactivity retention cron (ADR-011). Refreshed on every
  // registration linked to this person.
  lastActiveAt    DateTime @default(now()) @map("last_active_at")
  retentionMonths Int      @default(24) @map("retention_months")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  registrations Registration[]
  invitations   EventInvitation[]
  speakers      Speaker[]

  @@index([optedInToAddressBook, lastActiveAt])
  @@map("persons")
}

// ── Email outbox ────────────────────────────────────────────
//
// Persistent queue for outgoing emails. Producers (registration API,
// reminder cron, notification helpers) insert a row; the processor
// cron (/api/cron/email-outbox) pulls PENDING rows with FOR UPDATE
// SKIP LOCKED, sends them via SMTP (pooled), and marks SENT or
// re-schedules with exponential backoff.
//
// Rationale: previously the registration API fired a non-blocking
// Promise that hit SMTP inside the app pod. SMTP handshake + slow
// upstream providers inflated tail latency and, worse, dropped mails
// silently on pod restart. The outbox makes delivery durable and
// decouples user-facing latency from SMTP.
enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

model EmailOutbox {
  id String @id @default(uuid()) @db.Uuid

  // Delivery target. toAddress, html and text are stored as
  // AES-256-GCM ciphertext (base64) — see src/lib/email/outbox.ts and
  // src/lib/crypto/pii.ts. `subject` is plaintext on purpose (event
  // title, already public). Prisma `String` with no length modifier
  // maps to PostgreSQL `text`, which fits arbitrary ciphertext.
  toAddress   String  @map("to_address")
  subject     String
  html        String
  text        String?
  // Array of { filename, contentBase64, contentType } — base64 so we
  // don't have to worry about binary encoding in JSONB.
  attachments Json?   @db.JsonB

  // Scheduling
  status        EmailOutboxStatus @default(PENDING)
  attempts      Int               @default(0)
  nextAttemptAt DateTime          @default(now()) @map("next_attempt_at")
  sentAt        DateTime?         @map("sent_at")
  lastError     String?           @map("last_error")

  // Free-form metadata for traceability — e.g. { kind: 'confirmation',
  // registrationId, eventId }. Not used by the processor; the producer
  // owns the shape.
  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Processor query: PENDING rows ready to be sent, oldest first.
  @@index([status, nextAttemptAt])
  @@map("email_outbox")
}

// ─── Postprod AI pipeline ───────────────────────────────────
//
// Adds a post-production lifecycle on top of the existing Jibri
// recording flow: transcription (WhisperX + pyannote), summary
// (LLM), translation, subtitles (WebVTT), and — in a separate
// gated workflow not modelled here — voice-cloned dubbing (Art. 9
// GDPR, intentionally absent from MVP/V1).
//
// Design notes:
//   • Anchored to `CallSession` (1:1) rather than `Event`, since
//     `CallSession` is already the timeline source-of-truth.
//   • Job-queue uses the Postgres outbox pattern (claim with FOR
//     UPDATE SKIP LOCKED), mirroring `EmailOutbox`. No Redis stream
//     or external workflow engine.
//   • One row per produced blob in `PostprodArtifact`; multilingual
//     fan-out is `(type, language)` rather than columns-per-language.
//   • `Speaker` carries the diarization → identity mapping. Voice
//     embeddings (Art. 9) are deliberately NOT stored here.

enum RecordingStatus {
  READY
  POSTPROD_QUEUED
  POSTPROD_RUNNING
  POSTPROD_PARTIAL
  POSTPROD_DONE
  POSTPROD_FAILED
  ARCHIVED
}

enum PostprodJobKind {
  TRANSCRIBE
  // Trascrizione multi-traccia (ADR-013): una traccia audio per
  // partecipante (registrate separatamente dal multitrack-recorder).
  // Ogni traccia ha UN solo parlante noto → niente diarization pyannote;
  // i segmenti delle tracce vengono fusi su timeline globale con
  // attribuzione certa + overlap nativi. Vedi infra/ai/worker/multitrack.py.
  TRANSCRIBE_MULTITRACK
  SUMMARIZE
  TRANSLATE
  SUBTITLE
  // Dubbing TTS in lingua target: TTS *neutro* (voce sintetica non
  // clonata) sul transcript tradotto. Produce un file audio per
  // lingua + (V2) un MP4 con audio sostituito. Marker AI Act Art. 50
  // applicato a tutti gli artefatti DUB.
  DUB
  // Archivio scaricabile (on-demand): muxa il video Jibri + N tracce
  // audio per-partecipante (etichettate col nome, allineate via
  // cross-correlazione) + sottotitoli VTT in un singolo file MKV.
  // Richiede Event.retainParticipantTracks (le tracce devono essere
  // ancora presenti, non purgate). Vedi infra/ai/worker/archive.py.
  ARCHIVE
}

enum PostprodJobStatus {
  PENDING
  CLAIMED
  RUNNING
  DONE
  FAILED
}

enum PostprodArtifactType {
  TRANSCRIPT_JSON
  TRANSCRIPT_VTT
  TRANSCRIPT_TXT
  // Picchi audio pre-calcolati (envelope normalizzato 0..1) per la
  // waveform/timeline dell'editor admin. Evita di scaricare l'MP4
  // intero nel browser: il worker decodifica l'audio una volta e ne
  // salva una rappresentazione compatta (~qualche KB) come JSON.
  // language=null (globale alla registrazione, come TRANSCRIPT_JSON).
  WAVEFORM_JSON
  SUMMARY_MD
  // Sintesi strutturata (overall_summary, key_decisions, action_items,
  // topics[{title, start_mmss, summary}]) per lingua. Permette al
  // frontend di renderizzare il post-evento con hero card + topic-chip
  // navigator invece del solo blob markdown.
  SUMMARY_JSON
  SUBTITLE_VTT
  TRANSLATION_VTT
  TRANSLATION_MD
  // Audio sintetico (TTS neutro) per lingua target. AAC encoded,
  // stesso minutaggio del video originale (segmenti TTS-aligned con
  // i timestamp del transcript). Player lo carica come traccia
  // alternativa via <audio src=...> con sync manuale (V1) o HLS
  // multi-track (V2).
  DUBBED_AUDIO
  // (V2) MP4 con audio originale sostituito da DUBBED_AUDIO. Utile
  // per download offline. Non prodotto in MVP per evitare ridondanza
  // storage.
  DUBBED_VIDEO
  // Archivio multi-traccia (job ARCHIVE): un MKV con il video Jibri +
  // una traccia audio per-partecipante (etichettata col displayName,
  // allineata via cross-correlazione) + i sottotitoli VTT come traccia
  // sottotitoli embedded. language=null (è un contenitore multi-lingua).
  // Contiene voce isolata per-partecipante (PII sensibile) → scaricabile
  // solo da admin/moderatore, mai esposto pubblicamente.
  ARCHIVE_MKV
}

model Recording {
  id            String @id @default(uuid()) @db.Uuid
  // 1:1 with CallSession. Recording rows live longer than the call
  // (artifacts may outlive the session row depending on retention).
  callSessionId String @unique @map("call_session_id") @db.Uuid
  eventId       String @map("event_id") @db.Uuid

  // Reference to the source MP4 in object storage (provider-agnostic
  // key, NOT a signed URL). Resolved through StorageProvider at read
  // time. Denormalised from CallSession.recordingFilename for the
  // common case "load Recording without joining CallSession".
  blobKey        String  @map("blob_key")
  durationSec    Int?    @map("duration_sec")
  fileSizeBytes  BigInt? @map("file_size_bytes")
  // Source language hint passed to ASR (`it` by default). Can be null
  // if the admin doesn't know; the worker will let WhisperX detect.
  sourceLanguage String? @map("source_language") @db.VarChar(8)

  status RecordingStatus @default(READY)

  // Snapshot of consent flags at enqueue time, so a retroactive change
  // on Event.* doesn't silently invalidate already-produced artifacts.
  consentSnapshot Json @default("{}") @map("consent_snapshot") @db.JsonB

  // Snapshot della composizione effettiva della pipeline AI usata per
  // questa specifica registrazione (motori, modelli, versioni,
  // assegnazione voci, lingue, data run). NON segue le impostazioni
  // correnti di SiteSetting: è una fotografia del momento. Esposta
  // al visitatore del video come "Dettagli del processing AI", per
  // trasparenza ai sensi dell'AI Act Art. 50.
  //
  // Shape attesa (è JSON libero per evolvere senza migration):
  //   {
  //     asr: {engine, model, version},
  //     diarization: {engine, model, k, method},
  //     llm: {engine, model, vendor, license},
  //     tts: {engine, version, voices: ["alan","amy",…]},
  //     voiceAssignments: [{diarLabel, displayName, voiceId, gender}],
  //     languages: {source, translation: [...], dubbing: [...]},
  //     runAt: ISO timestamp,
  //     pipelineVersion: "git-sha"
  //   }
  pipelineSnapshot Json @default("{}") @map("pipeline_snapshot") @db.JsonB

  // Run counter — incremented every time the orchestrator re-enqueues
  // the full pipeline (manual retry from admin UI). Used in the
  // storage path so old runs survive until retention.
  runCount Int @default(1) @map("run_count")

  // Retention: when set, artifacts beyond this date are purged by the
  // postprod-retention cron. Null = follow event retention.
  retentionUntil DateTime? @map("retention_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  callSession CallSession        @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  jobs        PostprodJob[]
  artifacts   PostprodArtifact[]
  tracks      RecordingTrack[]
  speakers    Speaker[]

  @@index([eventId])
  @@index([status])
  @@map("recordings")
}

// ADR-013 Fase 2 — una traccia audio per-partecipante prodotta dal
// multitrack-recorder. A differenza dello Speaker (cluster pyannote
// mappato a mano), qui l'identità è CERTA (dal JWB del portale). Il
// worker trascrive ogni traccia senza diarization e fonde i segmenti.
// L'audio per-partecipante è PII quasi-biometrica → retention BREVE
// (le tracce sono input intermedio, cancellabili dopo la trascrizione)
// e mai esposto al pubblico (solo input worker via signed URL).
model RecordingTrack {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @map("recording_id") @db.Uuid

  // Identità del partecipante dal JWT del portale (endpoint id / sub).
  participantId String  @map("participant_id")
  // displayName cifrato a riposo (AES-256-GCM via encryptPII) — PII.
  displayName   String? @map("display_name")

  // Chiave provider-agnostica della traccia audio in object storage.
  blobKey   String  @map("blob_key")
  mimeType  String  @default("audio/ogg") @map("mime_type")
  sizeBytes BigInt? @map("size_bytes")

  // Offset di inizio traccia rispetto al t0 della registrazione (ms) e
  // durata (ms): servono al merge per allineare le tracce sulla stessa
  // timeline globale.
  startOffsetMs Int  @default(0) @map("start_offset_ms")
  durationMs    Int? @map("duration_ms")

  // Quando la traccia (audio grezzo PII) è stata cancellata dopo la
  // trascrizione — minimizzazione GDPR. Null = ancora presente.
  audioPurgedAt DateTime? @map("audio_purged_at")

  createdAt DateTime @default(now()) @map("created_at")

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  // Univoco per SESSIONE di traccia (blobKey include il trackFileId =
  // ${pid}-${seq}), NON per partecipante: un rejoin / mute->unmute dello
  // stesso partecipante produce un blob distinto e quindi una riga distinta
  // (prima il vincolo (recordingId, participantId) collassava le sessioni
  // sullo stesso upsert → l'audio del secondo intervento andava perso).
  // Il worker (multitrack.py) rifonde le righe dello stesso participantId
  // sotto un unico speaker.
  @@unique([recordingId, blobKey])
  @@index([recordingId])
  @@index([recordingId, participantId])
  @@map("recording_tracks")
}

model PostprodJob {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @map("recording_id") @db.Uuid

  kind    PostprodJobKind
  // Free-form params validated by lib/ai Zod schemas at enqueue +
  // claim time. Shape varies by `kind`:
  //   TRANSCRIBE: { runId, sourceLanguage?, model?: 'large-v3' }
  //   SUMMARIZE:  { runId, sourceLanguage, transcriptArtifactId }
  //   TRANSLATE:  { runId, sourceLanguage, targetLanguage,
  //                 transcriptArtifactId, summaryArtifactId? }
  //   SUBTITLE:   { runId, language, transcriptArtifactId }
  payload Json            @db.JsonB

  status        PostprodJobStatus @default(PENDING)
  attempts      Int               @default(0)
  nextAttemptAt DateTime          @default(now()) @map("next_attempt_at")

  // Lease bookkeeping (mirrors EmailOutbox). When CLAIMED but
  // next_attempt_at expires, the orchestrator reclaims it on next tick.
  leasedAt DateTime? @map("leased_at")
  leasedBy String?   @map("leased_by") // worker pod name

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  lastError   String?   @map("last_error") @db.Text

  // Deterministic key so retries / webhook re-deliveries don't enqueue
  // duplicates. Built as sha256(recordingId|kind|canonical(payload)).
  idempotencyKey String @unique @map("idempotency_key")

  // Optional FK to a precursor: SUMMARIZE depends on TRANSCRIBE
  // completing. Used by the orchestrator's "ready jobs" query.
  dependsOnId String? @map("depends_on_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recording  Recording          @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  dependsOn  PostprodJob?       @relation("PostprodJobDeps", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependents PostprodJob[]      @relation("PostprodJobDeps")
  artifacts  PostprodArtifact[]

  @@index([status, nextAttemptAt])
  @@index([recordingId])
  @@map("postprod_jobs")
}

model PostprodArtifact {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @map("recording_id") @db.Uuid
  jobId       String @map("job_id") @db.Uuid

  type     PostprodArtifactType
  // ISO-639-1 — null for type-agnostic artifacts (TRANSCRIPT_JSON
  // which holds the multi-language raw output isn't expected today;
  // we still keep this nullable to leave space).
  language String?              @db.VarChar(8)

  // Provider-agnostic key in object storage.
  blobKey   String  @map("blob_key")
  sizeBytes BigInt? @map("size_bytes")
  mimeType  String  @map("mime_type")

  // Small artifacts (transcript text < 64KB, summary md) may be
  // mirrored inline for cheap render. AES-256-GCM via encryptPII
  // (PII surface: contains participant names + speech).
  inlineBody String? @map("inline_body") @db.Text

  // Hash for cache invalidation + integrity check.
  contentHash String @map("content_hash") @db.VarChar(64)

  // AI Act Art. 50 — anything produced by an AI pipeline is flagged
  // synthetic, even if "just" a transcription. The UI uses this to
  // render the "AI-generated" badge.
  isSynthetic   Boolean @default(true) @map("is_synthetic")
  watermarkType String? @map("watermark_type") // null | "audioseal" (V3)

  // Provenance for traceability: which model + version produced this.
  modelId      String? @map("model_id") @db.VarChar(120)
  modelVersion String? @map("model_version") @db.VarChar(80)

  createdAt DateTime @default(now()) @map("created_at")

  recording Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  job       PostprodJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // One (type, language) per recording — newer runs replace older.
  @@unique([recordingId, type, language])
  @@index([recordingId])
  @@map("postprod_artifacts")
}

model Speaker {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @map("recording_id") @db.Uuid

  // Diarization output label, e.g. "SPEAKER_00". Stable inside a
  // single recording; not portable across recordings.
  diarLabel String @map("diar_label") @db.VarChar(40)

  // Manual mapping target. Either a Person from the rubrica or a free-
  // text display name (e.g. an external guest never in rubrica).
  displayName String? @map("display_name")
  personId    String? @map("person_id") @db.Uuid

  // Total speaking time in seconds (denormalised from transcript).
  // Convenient for the admin UI ranking.
  totalSpeechSec Int @default(0) @map("total_speech_sec")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  person    Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([recordingId, diarLabel])
  @@index([personId])
  @@map("speakers")
}
