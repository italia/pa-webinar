    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.9.6",
    "prisma": "^6.0.0",
    "sass": "^1.101.7",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
